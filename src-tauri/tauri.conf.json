{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moaz Elgabry Plugins",
  "version": "0.1.22",
  "identifier": "com.moazelgabry.pluginmanager",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Moaz Elgabry Plugins",
        "width": 1180,
        "height": 860,
        "minWidth": 900,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": [
      "app",
      "appimage",
      "dmg",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDNkVCMkQ3RUZEMzEwRgpSV1FQTWYxK0xldkdEcmhmWHBkNU02QVkwZFZnZEUyM0JLd0VKVDBXZWxXSEh2aHNreGFEaWJaawo=",
      "endpoints": [
        "https://moazelgabry.github.io/Moaz-Elgabry-plugins/updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
